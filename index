          <!-- Left arm holds clipboard -->
          <line x1="34" y1="44" x2="18" y2="50" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>

          <!-- Right arm raised POINTING / directing -->
          <line x1="66" y1="38" x2="90" y2="18" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
