          <rect x="65" y="34" width="8" height="6" rx="1" fill="#185FA5" opacity="0.2"/>
          <rect x="76" y="34" width="8" height="6" rx="1" fill="#185FA5" opacity="0.2"/>
          <rect x="87" y="34" width="8" height="6" rx="1" fill="#185FA5" opacity="0.2"/>

          <!-- Left arm holding clipboard from below -->
          <line x1="34" y1="44" x2="60" y2="44" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Right arm raised with pencil writing -->
          <line x1="62" y1="40" x2="82" y2="52" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Pencil -->
          <line x1="84" y1="50" x2="96" y2="72" stroke="#E8C44A" stroke-width="5" stroke-linecap="round"/>
          <polygon points="94,69 99,73 95,77 90,73" fill="#333" opacity="0.7"/>
          <!-- Writing motion dot at pencil tip -->
          <circle cx="95" cy="74" r="2" fill="#1A1A1A" opacity="0.5"/>
        </svg>
      </div>
      <div class="card-title">Recorder</div>
    </div>

    <!-- STEP 9: CULLER — IN SITU — QUALITY CRITICAL -->
    <div class="card t-amber">
      <div class="card-step">9</div>
      <div class="card-badge">Quality</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- GOOD BOX (left) — green check -->
          <rect x="4" y="58" width="32" height="26" rx="3" fill="#EBF5E1" stroke="#2E6B14" stroke-width="3"/>
