    <!-- STEP 11: HOMEOWNER INTERFACE — HIGHEST TRUST -->
    <div class="card t-green">
      <div class="card-step">11</div>
      <div class="card-badge">Highest Trust</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- DOOR frame on right (homeowner is at their door) -->
          <rect x="80" y="14" width="26" height="68" rx="2" fill="#F5E8D0" stroke="#8B6914" stroke-width="2.5"/>
