          <!-- Fruit in left hand (good — going into good box) -->
          <circle cx="22" cy="55" r="7" fill="#E87D0D"/>
          <!-- Damaged fruit in right hand (going to reject) -->
          <circle cx="87" cy="57" r="7" fill="#CC3322" opacity="0.75"/>
          <!-- Crack on damaged fruit -->
          <path d="M 85 53 L 84 57 L 88 55 L 87 60" fill="none" stroke="#800" stroke-width="1.5"/>

