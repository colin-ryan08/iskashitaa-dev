<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Iskashitaa Gleaning Program — Volunteer Role Reference</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    @page {
      size: letter landscape;
      margin: 0.28in;
    }

    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background: #e8e8e8;
      padding: 18px;
    }

    @media print {
      body { background: white; padding: 0; }
      .page { box-shadow: none; }
    }

    .page {
      background: white;
      width: 10.44in;
      min-height: 7.94in;
      margin: 0 auto;
      padding: 0.2in 0.22in 0.18in;
      box-shadow: 0 2px 16px rgba(0,0,0,0.15);
      display: flex;
      flex-direction: column;
    }

    /* ——— HEADER ——— */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 7px;
      padding-bottom: 5px;
      border-bottom: 2.5px solid #1B3A5C;
    }
    .page-title {
      font-size: 11.5pt;
      font-weight: 800;
      color: #1B3A5C;
      letter-spacing: 0.015em;
    }
    .page-sub {
      font-size: 7.5pt;
      color: #666;
      font-style: italic;
      margin-top: 2px;
    }
    .page-logo {
      font-size: 7pt;
      color: #999;
      text-align: right;
    }

    /* ——— GRID ——— */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: 7px;
      flex: 1;
    }

    /* ——— CARD ——— */
    .card {
      border: 1px solid #ccc;
      border-top: 4px solid var(--c, #185FA5);
      border-radius: 6px;
      background: var(--bg, #F5F9FF);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 5px 4px 6px;
      position: relative;
      overflow: hidden;
    }

    .card-step {
      position: absolute;
      top: 6px;
      left: 6px;
      background: var(--c, #185FA5);
      color: white;
      font-size: 9.5pt;
      font-weight: 800;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      z-index: 2;
    }

    .card-badge {
      position: absolute;
      top: 8px;
      right: 6px;
      font-size: 6pt;
      font-weight: 700;
      padding: 2px 5px;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      z-index: 2;
      background: var(--badge-bg, #E6F1FB);
      color: var(--c, #185FA5);
    }

    .card-fig {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 2px 6px;
      margin-top: 6px;
    }

    .card-fig svg {
      width: 100%;
      height: 100%;
      max-height: 155px;
    }

    .card-title {
      font-size: 8.5pt;
      font-weight: 700;
      text-align: center;
      color: #111;
      line-height: 1.2;
      margin-top: 3px;
    }

    /* ——— COLOR TYPES ——— */
    .t-blue  { --c: #185FA5; --bg: #F4F8FF; --badge-bg: #E0EDFF; }
    .t-red   { --c: #A32D2D; --bg: #FFF5F5; --badge-bg: #FDEDED; }
    .t-amber { --c: #854F0B; --bg: #FFFBF4; --badge-bg: #FEF3E2; }
    .t-green { --c: #2E6B14; --bg: #F4FBF0; --badge-bg: #E5F5DC; }
    .t-navy  { --c: #1B3A5C; --bg: #F2F5FA; --badge-bg: #E2EBF4; }

    /* ——— LEGEND CARD ——— */
    .legend-card {
      grid-column: span 2;
      border: 1px solid #ccc;
      border-top: 4px solid #888;
      border-radius: 6px;
      background: #F9F9F7;
      padding: 10px 14px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .legend-title {
      font-size: 8pt;
      font-weight: 700;
      color: #444;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    .legend-rows {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5px 10px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 7.5pt;
      color: #333;
    }

    .ldot {
      width: 13px;
      height: 13px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .legend-note {
      font-size: 6.8pt;
      color: #666;
      font-style: italic;
      margin-top: 9px;
      line-height: 1.5;
      border-top: 1px solid #ddd;
      padding-top: 6px;
    }
  </style>
</head>
<body>
<div class="page">

  <div class="page-header">
    <div>
      <div class="page-title">Iskashitaa Gleaning Program — Volunteer Role Reference</div>
      <div class="page-sub">Point to assign a role on-site · Steps 1 → 11 show increasing experience &amp; responsibility</div>
    </div>
    <div class="page-logo">iskashitaa.org</div>
  </div>

  <div class="card-grid">

    <!-- ═══════════════════════════════════════ ROW 1 ═══ -->

    <!-- STEP 1: HAND PICKER -->
    <div class="card t-blue">
      <div class="card-step">1</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- Legs -->
          <line x1="40" y1="70" x2="31" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="44" y1="70" x2="53" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <!-- Body -->
          <polygon points="29,32 57,32 53,70 33,70" fill="#1A1A1A"/>
          <!-- Left arm hangs down-left -->
          <line x1="29" y1="42" x2="17" y2="60" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Right arm raised toward branch at upper right -->
          <line x1="57" y1="36" x2="80" y2="18" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Head -->
          <circle cx="42" cy="14" r="13" fill="#1A1A1A"/>

          <!-- Tree branch sweeping from upper right -->
          <path d="M 110 4 Q 100 6 80 18" stroke="#4a7c59" stroke-width="6" fill="none" stroke-linecap="round"/>
          <path d="M 102 22 Q 93 17 86 28" stroke="#4a7c59" stroke-width="5" fill="none" stroke-linecap="round"/>
          <!-- Leaves suggestion -->
          <ellipse cx="104" cy="10" rx="7" ry="4" fill="#4a7c59" opacity="0.5" transform="rotate(-20 104 10)"/>
          <!-- Fruits on branch -->
          <circle cx="80" cy="18" r="8" fill="#E87D0D"/>
          <circle cx="97" cy="19" r="7" fill="#DD4B22"/>
          <circle cx="88" cy="30" r="6" fill="#E87D0D"/>
        </svg>
      </div>
      <div class="card-title">Hand Picker</div>
    </div>

    <!-- STEP 2: PICKER WITH TOOL -->
    <div class="card t-blue">
      <div class="card-step">2</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- Legs slightly apart for stability -->
          <line x1="44" y1="70" x2="34" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="48" y1="70" x2="58" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <!-- Body -->
          <polygon points="32,32 60,32 56,70 36,70" fill="#1A1A1A"/>
          <!-- Head -->
          <circle cx="44" cy="14" r="13" fill="#1A1A1A"/>

          <!-- POLE — long diagonal from lower grip up to basket at top-right -->
          <line x1="50" y1="64" x2="109" y2="5" stroke="#8B6914" stroke-width="6" stroke-linecap="round"/>

          <!-- Right arm grips upper pole -->
          <line x1="60" y1="40" x2="76" y2="34" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Left arm grips lower pole -->
          <line x1="32" y1="46" x2="48" y2="58" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>

          <!-- Basket cup at pole tip -->
          <path d="M 103 5 Q 109 3 109 10 L 106 15 L 101 17 L 96 15 L 93 10 Q 93 3 103 5 Z" fill="none" stroke="#8B6914" stroke-width="2.5"/>
          <!-- Fruit captured in basket -->
          <circle cx="101" cy="9" r="7" fill="#E87D0D"/>
          <!-- Branch nearby suggesting source -->
          <path d="M 108 0 Q 112 6 109 10" stroke="#4a7c59" stroke-width="3.5" fill="none" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="card-title">Picker with Tool</div>
    </div>

    <!-- STEP 3: GROUND GATHERER -->
    <div class="card t-blue">
      <div class="card-step">3</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- Legs (straight down from hips while torso bends forward) -->
          <line x1="42" y1="74" x2="33" y2="110" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="50" y1="74" x2="54" y2="110" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>

          <!-- Torso — thick angled line from hips forward to shoulder -->
          <line x1="46" y1="72" x2="79" y2="44" stroke="#1A1A1A" stroke-width="20" stroke-linecap="round"/>

          <!-- Head at end of bent torso -->
          <circle cx="84" cy="31" r="13" fill="#1A1A1A"/>

          <!-- Both arms reach DOWN toward fruit on ground -->
          <line x1="74" y1="52" x2="62" y2="84" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <line x1="84" y1="52" x2="96" y2="80" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>

          <!-- Ground line -->
          <line x1="4" y1="110" x2="106" y2="110" stroke="#8B6914" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>

          <!-- Fruit scattered on ground -->
          <circle cx="46" cy="106" r="7" fill="#E87D0D"/>
          <circle cx="62" cy="105" r="6" fill="#DD4B22"/>
          <circle cx="76" cy="107" r="7" fill="#E87D0D"/>
          <circle cx="90" cy="105" r="6" fill="#E87D0D"/>

          <!-- Basket/bucket collecting fruit (optional) -->
          <path d="M 24 95 L 20 110 L 38 110 L 34 95 Z" fill="none" stroke="#8B6914" stroke-width="2.5"/>
          <circle cx="30" cy="103" r="4" fill="#E87D0D"/>
        </svg>
      </div>
      <div class="card-title">Ground Gatherer</div>
    </div>

    <!-- STEP 4: LADDER SPOTTER — SAFETY CRITICAL -->
    <div class="card t-red">
      <div class="card-step">4</div>
      <div class="card-badge">Safety</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- LADDER (prominent, right two-thirds of image) -->
          <!-- Left rail -->
          <line x1="68" y1="5" x2="68" y2="112" stroke="#888" stroke-width="5" stroke-linecap="round"/>
          <!-- Right rail -->
          <line x1="88" y1="5" x2="88" y2="112" stroke="#888" stroke-width="5" stroke-linecap="round"/>
          <!-- Rungs -->
          <line x1="68" y1="20" x2="88" y2="20" stroke="#888" stroke-width="4"/>
          <line x1="68" y1="35" x2="88" y2="35" stroke="#888" stroke-width="4"/>
          <line x1="68" y1="50" x2="88" y2="50" stroke="#888" stroke-width="4"/>
          <line x1="68" y1="65" x2="88" y2="65" stroke="#888" stroke-width="4"/>
          <line x1="68" y1="80" x2="88" y2="80" stroke="#888" stroke-width="4"/>
          <line x1="68" y1="95" x2="88" y2="95" stroke="#888" stroke-width="4"/>

          <!-- Ghost of picker on upper ladder (legs visible) -->
          <line x1="73" y1="20" x2="71" y2="38" stroke="#1A1A1A" stroke-width="5" opacity="0.25" stroke-linecap="round"/>
          <line x1="83" y1="20" x2="85" y2="38" stroke="#1A1A1A" stroke-width="5" opacity="0.25" stroke-linecap="round"/>
          <circle cx="78" cy="12" r="7" fill="#1A1A1A" opacity="0.2"/>

          <!-- SPOTTER — left of ladder, body angled toward it, arms extended to rails -->
          <!-- Legs -->
          <line x1="28" y1="74" x2="18" y2="110" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="32" y1="74" x2="42" y2="110" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <!-- Body (angled slightly toward ladder) -->
          <polygon points="17,34 45,34 41,74 21,74" fill="#1A1A1A"/>
          <!-- Head (slightly turned toward ladder) -->
          <circle cx="29" cy="16" r="13" fill="#1A1A1A"/>
          <!-- Left arm reaching to left rail at y~42 -->
          <line x1="17" y1="44" x2="68" y2="42" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Right arm reaching to right rail -->
          <line x1="45" y1="42" x2="88" y2="50" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>

          <!-- Safety / warning triangle (small, top-left corner) -->
          <polygon points="4,5 14,22 -6,22" fill="#A32D2D" opacity="0.85"/>
          <line x1="4" y1="10" x2="4" y2="16" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <circle cx="4" cy="19" r="1.2" fill="white"/>
        </svg>
      </div>
      <div class="card-title">Ladder Spotter</div>
    </div>

    <!-- STEP 5: LADDER PICKER -->
    <div class="card t-blue">
      <div class="card-step">5</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- LADDER (left side of image) -->
          <line x1="14" y1="5" x2="14" y2="112" stroke="#888" stroke-width="5" stroke-linecap="round"/>
          <line x1="34" y1="5" x2="34" y2="112" stroke="#888" stroke-width="5" stroke-linecap="round"/>
          <line x1="14" y1="20" x2="34" y2="20" stroke="#888" stroke-width="4"/>
          <line x1="14" y1="35" x2="34" y2="35" stroke="#888" stroke-width="4"/>
          <line x1="14" y1="50" x2="34" y2="50" stroke="#888" stroke-width="4"/>
          <line x1="14" y1="65" x2="34" y2="65" stroke="#888" stroke-width="4"/>
          <line x1="14" y1="80" x2="34" y2="80" stroke="#888" stroke-width="4"/>
          <line x1="14" y1="95" x2="34" y2="95" stroke="#888" stroke-width="4"/>

          <!-- PERSON elevated on ladder — feet on rung at y~65, body above -->
          <!-- Feet/legs on rungs -->
          <line x1="20" y1="65" x2="20" y2="80" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="28" y1="65" x2="28" y2="80" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <!-- Body (torso, elevated) -->
          <polygon points="10,25 46,25 42,65 14,65" fill="#1A1A1A"/>
          <!-- Head -->
          <circle cx="28" cy="12" r="13" fill="#1A1A1A"/>
          <!-- Left hand gripping left rail -->
          <line x1="10" y1="38" x2="6" y2="30" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Right arm reaching OUT to fruit on branch -->
          <line x1="46" y1="34" x2="80" y2="26" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>

          <!-- Branch with fruit to the right -->
          <path d="M 110 8 Q 100 14 80 26" stroke="#4a7c59" stroke-width="5" fill="none" stroke-linecap="round"/>
          <path d="M 105 28 Q 96 22 88 32" stroke="#4a7c59" stroke-width="4" fill="none" stroke-linecap="round"/>
          <!-- Fruits near the reaching hand -->
          <circle cx="80" cy="26" r="8" fill="#E87D0D"/>
          <circle cx="95" cy="22" r="7" fill="#DD4B22"/>
          <circle cx="90" cy="34" r="6" fill="#E87D0D"/>
        </svg>
      </div>
      <div class="card-title">Ladder Picker</div>
    </div>

    <!-- ═══════════════════════════════════════ ROW 2 ═══ -->

    <!-- STEP 6: CRATE TRANSPORTER -->
    <div class="card t-blue">
      <div class="card-step">6</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- CRATE rendered first so person arms appear above -->
          <rect x="18" y="56" width="74" height="40" rx="4" fill="#F5E8D0" stroke="#8B6914" stroke-width="4"/>
          <!-- Crate top edge / lip -->
          <line x1="18" y1="68" x2="92" y2="68" stroke="#8B6914" stroke-width="2.5"/>
          <!-- Slat verticals -->
          <line x1="40" y1="68" x2="40" y2="96" stroke="#8B6914" stroke-width="2" opacity="0.5"/>
          <line x1="62" y1="68" x2="62" y2="96" stroke="#8B6914" stroke-width="2" opacity="0.5"/>
          <!-- Fruits in crate -->
          <circle cx="30" cy="79" r="7" fill="#E87D0D"/>
          <circle cx="55" cy="77" r="8" fill="#DD4B22"/>
          <circle cx="79" cy="79" r="7" fill="#E87D0D"/>

          <!-- Legs (behind crate, partially visible below) -->
          <line x1="48" y1="96" x2="37" y2="112" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="56" y1="96" x2="65" y2="112" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <!-- Body -->
          <polygon points="36,28 72,28 68,60 40,60" fill="#1A1A1A"/>
          <!-- Head -->
          <circle cx="54" cy="12" r="13" fill="#1A1A1A"/>
          <!-- Arms bending down to grip crate sides -->
          <line x1="36" y1="40" x2="20" y2="56" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <line x1="72" y1="40" x2="90" y2="56" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="card-title">Crate Transporter</div>
    </div>

    <!-- STEP 7: WEIGHER -->
    <div class="card t-blue">
      <div class="card-step">7</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- Person on left -->
          <line x1="28" y1="72" x2="18" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="32" y1="72" x2="42" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <polygon points="16,32 44,32 40,72 20,72" fill="#1A1A1A"/>
          <circle cx="30" cy="14" r="13" fill="#1A1A1A"/>
          <!-- Left arm at side -->
          <line x1="16" y1="44" x2="8" y2="62" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>
          <!-- Right arm pointing toward scale display -->
          <line x1="44" y1="42" x2="64" y2="50" stroke="#1A1A1A" stroke-width="7" stroke-linecap="round"/>

          <!-- HANGING SCALE (spring scale / Salter style) on right -->
          <!-- Mount bracket at top -->
          <rect x="68" y="5" width="28" height="9" rx="3" fill="#777"/>
          <line x1="82" y1="14" x2="82" y2="22" stroke="#555" stroke-width="3"/>
          <!-- S-hook -->
          <path d="M 82 22 Q 82 28 76 28 Q 70 28 70 22 L 70 20" fill="none" stroke="#555" stroke-width="3" stroke-linecap="round"/>
          <!-- Scale body (cylindrical) -->
          <rect x="70" y="28" width="24" height="38" rx="4" fill="#E8E4DC" stroke="#666" stroke-width="2.5"/>
          <!-- Scale window / dial -->
          <rect x="73" y="32" width="18" height="16" rx="2" fill="white" stroke="#aaa" stroke-width="1.5"/>
          <!-- Needle pointing to reading -->
          <line x1="82" y1="46" x2="87" y2="38" stroke="#A32D2D" stroke-width="2" stroke-linecap="round"/>
          <!-- Tick marks on dial -->
          <line x1="74" y1="34" x2="76" y2="34" stroke="#888" stroke-width="1.2"/>
          <line x1="74" y1="38" x2="76" y2="38" stroke="#888" stroke-width="1.2"/>
          <line x1="74" y1="42" x2="76" y2="42" stroke="#888" stroke-width="1.2"/>
          <line x1="74" y1="46" x2="76" y2="46" stroke="#888" stroke-width="1.2"/>
          <!-- Bottom hook -->
          <line x1="82" y1="66" x2="82" y2="76" stroke="#555" stroke-width="3"/>
          <path d="M 82 76 Q 82 82 88 82 Q 94 82 94 76" fill="none" stroke="#555" stroke-width="3" stroke-linecap="round"/>
          <!-- Fruit hanging from bottom hook -->
          <circle cx="88" cy="91" r="10" fill="#E87D0D"/>
          <!-- Bunch of fruit at base / already weighed pile -->
          <circle cx="68" cy="108" r="6" fill="#E87D0D"/>
          <circle cx="80" cy="106" r="5" fill="#DD4B22"/>
          <circle cx="92" cy="108" r="6" fill="#E87D0D"/>
        </svg>
      </div>
      <div class="card-title">Weigher</div>
    </div>

    <!-- STEP 8: RECORDER -->
    <div class="card t-blue">
      <div class="card-step">8</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- Legs -->
          <line x1="46" y1="72" x2="36" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <line x1="50" y1="72" x2="60" y2="108" stroke="#1A1A1A" stroke-width="8" stroke-linecap="round"/>
          <!-- Body -->
          <polygon points="34,32 62,32 58,72 38,72" fill="#1A1A1A"/>
          <!-- Head -->
          <circle cx="48" cy="14" r="13" fill="#1A1A1A"/>

          <!-- CLIPBOARD held in front, right side -->
          <!-- Board -->
          <rect x="60" y="26" width="40" height="52" rx="3" fill="#F5EDD5" stroke="#8B6914" stroke-width="2.5"/>
          <!-- Metal clip at top -->
          <rect x="73" y="22" width="14" height="9" rx="3" fill="#666" stroke="#444" stroke-width="1.5"/>
          <!-- Writing lines (data being recorded) -->
          <line x1="65" y1="40" x2="95" y2="40" stroke="#1A1A1A" stroke-width="1.8" opacity="0.45"/>
          <line x1="65" y1="49" x2="95" y2="49" stroke="#1A1A1A" stroke-width="1.8" opacity="0.45"/>
          <line x1="65" y1="58" x2="95" y2="58" stroke="#1A1A1A" stroke-width="1.8" opacity="0.45"/>
          <line x1="65" y1="67" x2="83" y2="67" stroke="#1A1A1A" stroke-width="1.8" opacity="0.45"/>
