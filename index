          <circle cx="58" cy="106" r="5" fill="#DD4B22"/>
          <circle cx="67" cy="104" r="5" fill="#E87D0D"/>
        </svg>
      </div>
      <div class="card-title">Culler — In Situ</div>
    </div>

    <!-- STEP 10: BRANCH RAKER -->
    <div class="card t-blue">
      <div class="card-step">10</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
