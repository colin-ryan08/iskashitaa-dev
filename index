          <line x1="80" y1="81" x2="78" y2="98" stroke="#1B3A5C" stroke-width="4" opacity="0.25" stroke-linecap="round"/>
          <line x1="94" y1="75" x2="92" y2="92" stroke="#1B3A5C" stroke-width="4" opacity="0.25" stroke-linecap="round"/>
          <line x1="105" y1="82" x2="103" y2="98" stroke="#1B3A5C" stroke-width="4" opacity="0.25" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="card-title">Harvest Lead</div>
    </div>

    <!-- DRIVER (Supporting) -->
    <div class="card t-navy">
      <div class="card-step" style="font-size:7.5pt;">D</div>
      <div class="card-badge">Support</div>
      <div class="card-fig">
        <svg viewBox="0 0 110 112" xmlns="http://www.w3.org/2000/svg">
          <!-- VAN BODY -->
          <rect x="4" y="46" width="102" height="48" rx="6" fill="#E8EEF5" stroke="#1B3A5C" stroke-width="3"/>
