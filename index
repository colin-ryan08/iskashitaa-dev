          <!-- DRIVER visible through windshield -->
          <circle cx="30" cy="36" r="8" fill="#1A1A1A"/>
          <!-- Steering wheel -->
          <circle cx="38" cy="46" r="8" fill="none" stroke="#1A1A1A" stroke-width="2.5"/>
          <line x1="38" y1="38" x2="38" y2="54" stroke="#1A1A1A" stroke-width="2"/>
          <line x1="30" y1="46" x2="46" y2="46" stroke="#1A1A1A" stroke-width="2"/>
          <!-- Arms to wheel -->
          <line x1="24" y1="42" x2="32" y2="46" stroke="#1A1A1A" stroke-width="4" stroke-linecap="round"/>
          <line x1="30" y1="41" x2="44" y2="43" stroke="#1A1A1A" stroke-width="4" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="card-title">Driver</div>
    </div>

    <!-- LEGEND CARD (spans 2 columns) -->
    <div class="legend-card">
      <div class="legend-title">Role Color Guide</div>
      <div class="legend-rows">
        <div class="legend-item">
          <span class="ldot" style="background:#185FA5;"></span>
          <span><strong>Blue</strong> — Standard progression role</span>
        </div>
        <div class="legend-item">
          <span class="ldot" style="background:#A32D2D;"></span>
          <span><strong>Red</strong> — Safety critical · No multitasking</span>
        </div>
        <div class="legend-item">
          <span class="ldot" style="background:#854F0B;"></span>
          <span><strong>Amber</strong> — Quality critical · Culling decisions</span>
        </div>
        <div class="legend-item">
          <span class="ldot" style="background:#2E6B14;"></span>
          <span><strong>Green</strong> — Highest trust · Homeowner contact</span>
        </div>
        <div class="legend-item">
          <span class="ldot" style="background:#1B3A5C;"></span>
          <span><strong>Navy</strong> — Supporting role (assigned separately)</span>
        </div>
      </div>
      <div class="legend-note">
        Steps 1–11 form the volunteer progression path. All new volunteers start at Step 1.
        Returning volunteers may be assessed and placed at the appropriate level by the Harvest Lead.
        Harvest Lead and Driver are assigned separately and are not part of the progression.
      </div>
    </div>

  </div><!-- /card-grid -->
